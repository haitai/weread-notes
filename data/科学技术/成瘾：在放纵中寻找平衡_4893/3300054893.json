  "hotBookmarks": [
    {
      "bookmarkId": "3300054893_8_10801-10828",
      "chapterUid": 8,
      "range": "10801-10828",
      "markText": "我们之所以如此痛苦，可能是因为我们一直在努力规避痛苦。",
      "totalCount": 2868,
      "appLink": "weread://bestbookmark?bookId=3300054893&chapterUid=8&rangeStart=10801&rangeEnd=10828",
      "webLink": "https://weread.qq.com/web/reader/9e8321b0813ab7bf1g013230?chapterUid=8&rangeStart=10801&rangeEnd=10828"
    },
    {
      "bookmarkId": "3300054893_9_1311-1368",
      "chapterUid": 9,
      "range": "1311-1368",
      "markText": "多巴胺的主要作用不是让人们在获得奖励后感到快乐，而是驱动人们产生获得奖励的动机。它促进了“想要”，而不是“喜欢”。",
      "totalCount": 2565,
      "appLink": "weread://bestbookmark?bookId=3300054893&chapterUid=9&rangeStart=1311&rangeEnd=1368",
      "webLink": "https://weread.qq.com/web/reader/9e8321b0813ab7bf1g013230?chapterUid=9&rangeStart=1311&rangeEnd=1368"
    },
    {
      "bookmarkId": "3300054893_7_9749-9814",
      "chapterUid": 7,
      "range": "9749-9814",
      "markText": "成瘾的最大风险因素之一是成瘾物质容易获取。当某一种东西更容易获得时，我们也更有可能使用这种东西。在使用的过程中，我们很可能会上瘾。",
      "totalCount": 2478,
      "appLink": "weread://bestbookmark?bookId=3300054893&chapterUid=7&rangeStart=9749&rangeEnd=9814",
      "webLink": "https://weread.qq.com/web/reader/9e8321b0813ab7bf1g013230?chapterUid=7&rangeStart=9749&rangeEnd=9814"
    },
    {
      "bookmarkId": "3300054893_9_12671-12715",
      "chapterUid": 9,
      "range": "12671-12715",
      "markText": "如果我们长时间反复接受愉悦的刺激，那么我们忍受痛苦的能力就会降低，快乐的门槛也随之提高。",
      "totalCount": 2394,
      "appLink": "weread://bestbookmark?bookId=3300054893&chapterUid=9&rangeStart=12671&rangeEnd=12715",
      "webLink": "https://weread.qq.com/web/reader/9e8321b0813ab7bf1g013230?chapterUid=9&rangeStart=12671&rangeEnd=12715"
    },
